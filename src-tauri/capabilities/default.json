{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "CCAR Copilot 默认权限配置",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-set-decorations",
    "core:window:allow-set-resizable",
    "core:window:allow-available-monitors",
    "core:window:allow-current-monitor",
    "core:window:allow-primary-monitor",
    "core:window:allow-inner-position",
    "core:window:allow-outer-position",
    "core:window:allow-inner-size",
    "core:window:allow-outer-size",
    "core:window:allow-scale-factor",
    "core:window:allow-is-visible",
    "core:window:allow-is-focused",
    "core:window:allow-is-maximized",
    "core:window:allow-is-minimized",
    "core:window:allow-is-decorated",
    "core:window:allow-is-resizable",
    "core:window:allow-title",
    "core:window:allow-set-title",
    "core:window:allow-maximize",
    "core:window:allow-minimize",
    "core:window:allow-unmaximize",
    "core:window:allow-unminimize",
    "core:window:allow-center",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "**" }
      ]
    },
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [
        { "path": "**" }
      ]
    },
    "fs:default",
    "fs:allow-exists",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-create",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:scope-appdata-recursive",
    "fs:scope-appcache-recursive",
    "fs:scope-applocaldata-recursive",
    "fs:scope-temp-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$TEMP" },
        { "path": "$TEMP/**" }
      ]
    },
    "fs:scope-picture-recursive",
    "fs:scope-document-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-download-recursive",
    "shell:default",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "process:default",
    "process:allow-restart",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install",
    "updater:allow-download-and-install"
  ]
}
