{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CCAR Copilot",
  "version": "0.1.0",
  "identifier": "com.wangh.ccarcopilot",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "createUpdaterArtifacts": true,
    "resources": [
      "openvino/*.dll",
      "openvino/cache.json",
      "pdfium/pdfium.dll"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CCAR Copilot",
        "width": 800,
        "height": 600,
        "center": true,
        "resizable": true,
        "visible": true,
        "focus": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPCACHE/**",
          "$RESOURCE/**",
          "$APPDATA/**",
          "$TEMP/**",
          "$PICTURE/**",
          "$DESKTOP/**",
          "$DOWNLOAD/**",
          "$DOCUMENT/**",
          "$HOME/**",
          "**"
        ]
      }
    }
  },
  "plugins": {}
}
