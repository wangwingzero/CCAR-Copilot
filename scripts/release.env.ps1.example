# -----------------------------------------------------------------------------
# CCAR Copilot 发布凭证模板
# -----------------------------------------------------------------------------
# 使用方法:
#   1. 把本文件复制为 scripts/release.env.ps1
#   2. 填入真实凭证
#   3. 直接跑 pwsh -File scripts/release.ps1 即可,脚本会自动加载
#
# 注意:
#   - scripts/release.env.ps1 已在 .gitignore 中排除,绝不要提交到 git
#   - 本文件(example)不含任何真实凭证,可以安全入库
# -----------------------------------------------------------------------------

# [必填] Tauri 签名私钥的绝对路径(.key 文件)
$env:TAURI_SIGNING_PRIVATE_KEY_PATH = "$HOME\.tauri\ccar-copilot-updater.key"

# [必填] 私钥密码。
# Tauri CLI 的坑: 即使 `tauri signer generate --ci` 声称"无密码",
# 生成的密钥文件仍是 `rsign encrypted secret key` 加密格式,空字符串密码
# 会被 build 阶段拒绝。所以生成密钥时必须传 --password "xxx"。
$env:TAURI_SIGNING_PRIVATE_KEY_PASSWORD = "your_key_password_here"

# [必填] 源站 SSH 私钥路径(用于 scp 上传更新包)
$env:RELEASE_SSH_KEY = "$HOME\.ssh\your_server_id_ed25519"

# [可选,有默认值] 源站连接参数
$env:RELEASE_SSH_HOST   = "154.9.27.44"
$env:RELEASE_SSH_USER   = "root"
$env:RELEASE_SSH_PORT   = "7668"
$env:RELEASE_REMOTE_DIR = "/www/wwwroot/ccar-release"

# [必填] Cloudflare zone ID (031986.xyz 的 zone)
$env:CF_ZONE_ID = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# [二选一] Cloudflare 认证方式
# 方式 A: Bearer Token(推荐,权限最小化)
# $env:CF_API_TOKEN = "your_scoped_token"
# 方式 B: Global API Key(老账号兜底)
$env:CF_EMAIL   = "you@example.com"
$env:CF_API_KEY = "your_global_api_key"
